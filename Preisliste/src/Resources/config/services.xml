<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true" public="false"/>

        <!-- CSV SERVICE -->
        <service id="Preisliste\Service\PriceListCsvService">
            <argument type="service" id="sales_channel.product.repository"/>
            <argument type="service" id="category.repository"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="logger" on-invalid="null"/>
        </service>

        <!-- ACCESS SERVICE -->
        <service id="Preisliste\Service\PriceListAccessService">
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
        </service>

        <!-- CONTROLLER -->
        <service id="Preisliste\Storefront\Controller\PriceListController" public="true">
            <argument type="service" id="Preisliste\Service\PriceListCsvService"/>
            <argument type="service" id="Preisliste\Service\PriceListAccessService"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="category.repository"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <!-- SUBSCRIBER -->
        <service id="Preisliste\Subscriber\ProductPriceCalculationSubscriber">
            <argument type="service" id="service_container"/>
            <argument type="service" id="logger" on-invalid="null"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
